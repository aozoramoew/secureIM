# ═══════════════════════════════════════════════════════════════════
#  SecureIM — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_SECRET_KEY=change-this-to-another-random-64-char-string

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, dev only):
DATABASE_URL=sqlite:///instance/secureIM.db
# PostgreSQL (production — Railway provides this automatically):
# DATABASE_URL=postgresql://user:password@host:5432/secureim

# ── Server ────────────────────────────────────────────────────────────────
DEBUG=true
BASE_URL=http://localhost:8000
PORT=8000

# ── E2EE session — rotate keys every N messages for forward secrecy
KEY_ROTATION_THRESHOLD=100

# ── Rate limiting ─────────────────────────────────────────────────────────
RATELIMIT_AUTH_LOGIN=10/minute
RATELIMIT_AUTH_REGISTER=5/hour
