# ═══════════════════════════════════════════════════════════════════
#  SecureIM — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_SECRET_KEY=change-this-to-another-random-64-char-string

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, dev only):
DATABASE_URL=sqlite:///instance/secureIM.db
# PostgreSQL (production — Railway provides this automatically):
# DATABASE_URL=postgresql://user:password@host:5432/secureim

# ── Server ────────────────────────────────────────────────────────────────
# DEBUG defaults to false — set to true only for local development
DEBUG=true
BASE_URL=http://localhost:8000
PORT=8000

# ── CORS — comma-separated allowed origins (defaults to http://localhost:PORT)
ALLOWED_ORIGINS=http://localhost:8000

# ── E2EE session — rotate keys every N messages for forward secrecy
KEY_ROTATION_THRESHOLD=100

# ── Rate limiting ─────────────────────────────────────────────────────────
RATELIMIT_AUTH_LOGIN=10/minute
RATELIMIT_AUTH_REGISTER=5/hour

# ── ML-WAF sidecar ────────────────────────────────────────────────────────
# Set MLWAF_ENABLED=true to activate. MLWAF_URL must point to the sidecar.
# In Docker Compose the sidecar is reachable at http://mlwaf:8001.
# For local dev without Docker, start ml-waf separately on port 8001.
MLWAF_ENABLED=false
MLWAF_URL=http://localhost:8001
MLWAF_TIMEOUT=0.5
# Optional: pass your CrowdSec API key to the ml-waf container
CROWDSEC_API_KEY=
