# ═══════════════════════════════════════════════════════════════════
#  SecureIM — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-run-python-secrets-token_hex-32
JWT_SECRET_KEY=change-this-to-another-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, dev only):
DATABASE_URL=sqlite:///secureIM.db
# PostgreSQL (production recommended — Railway provides this automatically):
# DATABASE_URL=postgresql://user:password@db:5432/secureim

# ── Email — OPTION 1: Resend API (RECOMMENDED — free, works on Railway) ──────
#
# Setup (3 steps, ~2 minutes):
#   1. Sign up FREE at https://resend.com  (no credit card required)
#   2. Go to Dashboard → API Keys → Create API Key
#   3. Add RESEND_API_KEY below
#
# Free tier: 3,000 emails/month, 100/day — enough for most projects.
# Works on Railway without any port or firewall issues.
#
RESEND_API_KEY=re_your_api_key_here
#
# From address options:
#   - No domain needed: onboarding@resend.dev  (works immediately, for testing)
#   - With your domain: noreply@yourdomain.com (verify domain in Resend dashboard)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Email — OPTION 2: Gmail SMTP (alternative) ────────────────────────────────
# Only needed if NOT using Resend. Gmail requires an App Password (not your login password).
# Enable: Google Account → Security → 2-Step Verification → App Passwords → Generate
#
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_DEFAULT_SENDER=SecureIM <noreply@yourdomain.com>

# ── Email — Dev Mode ─────────────────────────────────────────────────────────
# Set to true to suppress all emails and print links to the terminal instead.
# Default: true (dev), false (production)
MAIL_SUPPRESS_SEND=true

# ── App ───────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# FLASK_ENV=production
BASE_URL=http://localhost:5000
# On Railway, set this to your deployment URL:
# BASE_URL=https://your-app.up.railway.app
PORT=5000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Use Redis in production for distributed rate limiting:
# RATELIMIT_STORAGE_URL=redis://redis:6379/0

# ── Tuning ────────────────────────────────────────────────────────────────────
KEY_ROTATION_THRESHOLD=100
PAYLOAD_CLEANUP_HOURS=24
SOCKETIO_ASYNC_MODE=threading
# SOCKETIO_ASYNC_MODE=gevent   # use with gunicorn in production
