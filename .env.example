# ── Required ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-run-python-secrets-token_hex-32
JWT_SECRET_KEY=change-this-to-another-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, dev only):
DATABASE_URL=sqlite:///secureIM.db
# PostgreSQL (production recommended):
# DATABASE_URL=postgresql://user:password@db:5432/secureim

# ── Email ─────────────────────────────────────────────────────────────────────
# Set MAIL_SUPPRESS_SEND=true to print links to console (dev/testing).
# Set MAIL_SUPPRESS_SEND=false and configure SMTP for real emails (prod).
MAIL_SUPPRESS_SEND=true
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=SecureIM <noreply@yourdomain.com>

# ── App ───────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# FLASK_ENV=production
BASE_URL=http://localhost:5000
PORT=5000
LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Use Redis in production for distributed rate limiting:
# RATELIMIT_STORAGE_URL=redis://redis:6379/0

# ── Tuning ────────────────────────────────────────────────────────────────────
KEY_ROTATION_THRESHOLD=100
PAYLOAD_CLEANUP_HOURS=24
SOCKETIO_ASYNC_MODE=threading
# SOCKETIO_ASYNC_MODE=gevent   # use with gunicorn in production
